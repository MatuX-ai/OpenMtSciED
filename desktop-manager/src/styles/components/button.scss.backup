/* Button Component*/
/**/
/* 鎸夐挳缁勪欢鏍峰紡锛屾敮鎸佸绉嶄富棰樸€佸昂瀵稿拰鐘舵€佸彉浣?/
/* 浣跨敤 CSS 鑷畾涔夊睘鎬у疄鐜扮伒娲婚厤缃?/

/* 瀵煎叆 Design Tokens*/
@import '../design-tokens/index';

/* =============================================================================*/
/* 鎸夐挳鍩虹鏍峰紡*/
/* =============================================================================*/

.c-btn {
  --btn-border-radius: #{$border-radius-button};
  --btn-box-shadow: #{$shadow-button};
  --btn-font-size: #{$font-size-body-medium};
  --btn-font-weight: #{$font-weight-medium};
  --btn-height: 40px;
  --btn-padding: #{$spacing-sm} #{$spacing-lg};
  --btn-transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);

  position: relative;
  display: inline-flex;
  justify-content: center;
  align-items: center;
  min-width: 80px;
  height: var(--btn-height);
  padding: var(--btn-padding);
  border: none;
  border-radius: var(--btn-border-radius);
  background: none;
  box-shadow: var(--btn-box-shadow);
  color: currentcolor;
  font-family: $font-family-system;
  font-size: var(--btn-font-size);
  font-weight: var(--btn-font-weight);
  line-height: 1;
  text-align: center;
  vertical-align: middle;
  white-space: nowrap;
  text-decoration: none;
  cursor: pointer;
  user-select: none;
  transition: var(--btn-transition);
  /* CSS 鑷畾涔夊睘鎬у畾涔夊熀纭€閰嶇疆*/
  
  /* 鍩虹甯冨眬鍜屽瑙?/
  
  /* 灏哄璁剧疆*/
  
  /* 澶栬鏍峰紡*/
  
  /* 浜や簰鏁堟灉*/
  
  /* 鏂囧瓧鏍峰紡*/
  
  /* 鐒︾偣鐘舵€?/
  &:focus {
    outline: none;
    
    &::after {
  position: absolute;
  inset: -4px;
  border: 2px solid $focus-color;
  border-radius: calc(var(--btn-border-radius) + 4px);
  content: '';
  pointer-events: none;
}
  }
  
  /* 鎮仠鐘舵€?/
  &:hover:not(:disabled, .is-loading) {
    box-shadow: $shadow-button-hover;
    transform: translateY(-1px);
  }
  
  /* 婵€娲荤姸鎬?/
  &:active:not(:disabled, .is-loading) {
    transform: translateY(0);
  }
  
  /* 绂佺敤鐘舵€?/
  &:disabled {
    box-shadow: none;
    
    &:hover {
      box-shadow: none;
    
    &:hover {
      box-shadow: none;
      transform: none;
    }
  }
  
  /* 鍔犺浇鐘舵€?/
  &.is-loading {
    
    .c-btn__content {
      visibility: hidden;
    .c-btn__content {
      visibility: hidden;
    }
    
    .c-btn__spinner {
      display: inline-block;
    }
  }
  
  /* 鎸夐挳鍐呴儴鍏冪礌*/
  &__content {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    gap: $spacing-xs;
  }
  
  &__spinner {
    display: none;
    width: 16px;
    height: 16px;
    border: 2px solid currentcolor;
    border-right-color: transparent;
    border-radius: 50%;
    animation: c-btn-spin 1s linear infinite;
    
    &::before {
      content: '';
    }
  }
  
  /* 鍥炬爣鏍峰紡*/
  .c-icon {
    font-size: 1.1em;
  }
}

/* 鍔犺浇鍔ㄧ敾*/
@keyframes c-btn-spin {
  to {
    transform: rotate(360deg);
  }
}

/* =============================================================================*/
/* 鏆楅粦涓婚閫傞厤*/
/* =============================================================================*/

[data-theme="dark"] {
  .c-btn {
    /* 鏆楄壊涓婚涓嬬殑鐒︾偣鏍峰紡璋冩暣*/
    &:focus {
      &::after {
        border-color: var(--focus-color, rgb(187 134 252 / 50%));
      }
    }
    
    /* 鏆楄壊涓婚涓嬬殑鍔犺浇寰皟*/
    &.is-loading {
      .c-btn__spinner {
        border-color: currentcolor;
        border-right-color: transparent;
      }
    }
  }
  
  /* 鏆楄壊涓婚涓嬪悇鎸夐挳绫诲瀷鐨勯€傞厤*/
  .c-btn--primary {
    &.c-btn--text {
      --btn-hover-background: rgb(187 134 252 / 10%);
    }
  }
  
  .c-btn--secondary {
    &.c-btn--text {
      --btn-hover-background: rgb(3 218 198 / 10%);
    }
  }
  
  .c-btn--success {
    &.c-btn--text {
      --btn-hover-background: rgb(76 175 80 / 10%);
    }
  }
  
  .c-btn--warning {
    &.c-btn--text {
      --btn-hover-background: rgb(255 152 0 / 10%);
    }
  }
  
  .c-btn--error {
    &.c-btn--text {
      --btn-hover-background: rgb(207 102 121 / 10%);
    }
  }
  
  .c-btn--link {
    &:focus::after {
      border-color: var(--btn-color);
    }
  }
  
  /* 鎸夐挳缁勫湪鏆楄壊涓婚涓嬬殑杈规璋冩暣*/
  .c-btn-group {
    .c-btn {
      &:not(:first-child, :last-child) {
        border-left: 1px solid rgb(255 255 255 / 10%);
      }
    }
    
    &--vertical {
      .c-btn {
        &:not(:first-child, :last-child) {
          border-top: 1px solid rgb(255 255 255 / 10%);
          border-left: none;
        }
      }
    }
  }
}

/* =============================================================================*/
/* 鎸夐挳涓婚鍙樹綋*/
/* =============================================================================*/

/* 涓昏鎸夐挳*/
.c-btn--primary {
  
  background-color: var(--btn-background);
  
  &:hover:not(:disabled, .is-loading) {
    background-color: var(--btn-hover-background);
  color: var(--btn-color);
  
  &:hover:not(:disabled, .is-loading) {
    background-color: var(--btn-hover-background);
  }
  
  /* 杞粨鏍峰紡*/
  &.c-btn--outline {
    --btn-background: transparent;
    --btn-border: 2px solid #{$primary-color};
    --btn-color: #{$primary-color};
    --btn-hover-background: #{$primary-color};
    --btn-hover-color: #{$text-white-color};

    border: var(--btn-border);
    background-color: var(--btn-background);
    color: var(--btn-color);
    
    &:hover:not(:disabled, .is-loading) {
      background-color: var(--btn-hover-background);
      color: var(--btn-hover-color);
    }
  }
  
  /* 鏂囨湰鏍峰紡*/
  &.c-btn--text {
    --btn-background: transparent;
    --btn-box-shadow: none;
    --btn-color: #{$primary-color};
    --btn-hover-background: #{rgba($primary-color, 0.1)};
    --btn-hover-color: #{$primary-color-dark};
    
    background-color: var(--btn-background);
    box-shadow: var(--btn-box-shadow);
    color: var(--btn-color);
    
    &:hover:not(:disabled, .is-loading) {
      background-color: var(--btn-hover-background);
      color: var(--btn-hover-color);
    }
  }
}

/* 娆¤鎸夐挳*/
.c-btn--secondary {
  
  background-color: var(--btn-background);
  
  &:hover:not(:disabled, .is-loading) {
    background-color: var(--btn-hover-background);
  color: var(--btn-color);
  
  &:hover:not(:disabled, .is-loading) {
    background-color: var(--btn-hover-background);
  }
  
  /* 瀵瑰簲鐨勮疆寤撳拰鏂囨湰鏍峰紡*/
  &.c-btn--outline {
    --btn-background: transparent;
    --btn-border: 2px solid #{$secondary-color};
    --btn-color: #{$secondary-color};
    --btn-hover-background: #{$secondary-color};
    --btn-hover-color: #{$text-white-color};
  }
  
  &.c-btn--text {
    --btn-background: transparent;
    --btn-box-shadow: none;
    --btn-color: #{$secondary-color};
    --btn-hover-background: #{rgba($secondary-color, 0.1)};
    --btn-hover-color: #{$secondary-color-dark};
  }
}

/* 鎴愬姛鎸夐挳*/
.c-btn--success {
  
  background-color: var(--btn-background);
  
  &:hover:not(:disabled, .is-loading) {
    background-color: var(--btn-hover-background);
  color: var(--btn-color);
  
  &:hover:not(:disabled, .is-loading) {
    background-color: var(--btn-hover-background);
  }
  
  &.c-btn--outline {
    --btn-background: transparent;
    --btn-border: 2px solid #{$success-color};
    --btn-color: #{$success-color};
    --btn-hover-background: #{$success-color};
    --btn-hover-color: #{$text-white-color};
  }
  
  &.c-btn--text {
    --btn-background: transparent;
    --btn-box-shadow: none;
    --btn-color: #{$success-color};
    --btn-hover-background: #{rgba($success-color, 0.1)};
    --btn-hover-color: #{darken($success-color, 10%)};
  }
}

/* 璀﹀憡鎸夐挳*/
.c-btn--warning {
  
  background-color: var(--btn-background);
  
  &:hover:not(:disabled, .is-loading) {
    background-color: var(--btn-hover-background);
  color: var(--btn-color);
  
  &:hover:not(:disabled, .is-loading) {
    background-color: var(--btn-hover-background);
  }
  
  &.c-btn--outline {
    --btn-background: transparent;
    --btn-border: 2px solid #{$warning-color};
    --btn-color: #{$warning-color};
    --btn-hover-background: #{$warning-color};
    --btn-hover-color: #{$text-white-color};
  }
  
  &.c-btn--text {
    --btn-background: transparent;
    --btn-box-shadow: none;
    --btn-color: #{$warning-color};
    --btn-hover-background: #{rgba($warning-color, 0.1)};
    --btn-hover-color: #{darken($warning-color, 10%)};
  }
}

/* 閿欒鎸夐挳*/
.c-btn--error {
  
  background-color: var(--btn-background);
  
  &:hover:not(:disabled, .is-loading) {
    background-color: var(--btn-hover-background);
  color: var(--btn-color);
  
  &:hover:not(:disabled, .is-loading) {
    background-color: var(--btn-hover-background);
  }
  
  &.c-btn--outline {
    --btn-background: transparent;
    --btn-border: 2px solid #{$error-color};
    --btn-color: #{$error-color};
    --btn-hover-background: #{$error-color};
    --btn-hover-color: #{$text-white-color};
  }
  
  &.c-btn--text {
    --btn-background: transparent;
    --btn-box-shadow: none;
    --btn-color: #{$error-color};
    --btn-hover-background: #{rgba($error-color, 0.1)};
    --btn-hover-color: #{darken($error-color, 10%)};
  }
}

/* =============================================================================*/
/* 鎸夐挳灏哄鍙樹綋*/
/* =============================================================================*/

.c-btn--sm {
  --btn-font-size: #{$font-size-body-small};
  --btn-height: 32px;
  --btn-padding: #{$spacing-xs} #{$spacing-md};
}

.c-btn--lg {
  --btn-font-size: #{$font-size-body-large};
  --btn-height: 48px;
  --btn-padding: #{$spacing-md} #{$spacing-xl};
}

.c-btn--xl {
  --btn-font-size: #{$font-size-h6};
  --btn-height: 56px;
  --btn-padding: #{$spacing-lg} #{$spacing-xxl};
}

/* =============================================================================*/
/* 鎸夐挳褰㈢姸鍙樹綋*/
/* =============================================================================*/

.c-btn--pill {
  --btn-border-radius: #{$border-radius-full};
  --btn-padding: #{$spacing-sm} #{$spacing-xl};
}

.c-btn--square {
  --btn-border-radius: #{$border-radius-none};
}

.c-btn--circle {
  --btn-border-radius: #{$border-radius-full};

  width: var(--btn-height);
  min-width: var(--btn-height);
  padding: 0;
}

/* =============================================================================*/
/* 鎸夐挳鍔熻兘鍙樹綋*/
/* =============================================================================*/

.c-btn--block {
  display: flex;
  width: 100%;
}

.c-btn--icon-only {

  min-width: var(--btn-height);
  
  .c-btn__content {
  .c-btn__content {
    gap: 0;
  }
}

.c-btn--link {
  --btn-background: transparent;
  --btn-box-shadow: none;
  --btn-color: #{$link-color};
  --btn-hover-color: #{$link-hover-color};
  --btn-text-decoration: underline;
  
  background-color: var(--btn-background);
  box-shadow: var(--btn-box-shadow);
  color: var(--btn-color);
  text-decoration: var(--btn-text-decoration);
  
  &:hover:not(:disabled, .is-loading) {
    box-shadow: none;
    trans{
  box-shadow: none;
  color: var(--btn-hover-color);
  text-decoration: var(--btn-text-decoration);
  transform: none;
}r-color: var(--btn-color);
  }
}

/* =============================================================================*/
/* 鎸夐挳缁?/
/* =============================================================================*/

.c-btn-group {
  display: inline-flex;
  
  .c-btn {
    margin: 0;
    border-radius: 0;
    
    &:first-child {
      border-top-left-radius: var(--btn-border-radius);
      border-bottom-left-radius: var(--btn-border-radius);
    }
    
    &:last-child {
      border-top-right-radius: var(--btn-border-radius);
      border-bottom-right-radius: var(--btn-border-radius);
    }
    
    &:not(:first-child, :last-child) {
      border-left: 1px solid rgb(255 255 255 / 20%);
    }
  }
  
  /* 鍨傜洿鎸夐挳缁?/
  &--vertical {
    flex-direction: column;
    
    .c-btn {
      &:first-child {
        border-top-left-radius: var(--btn-border-radius);
        border-top-right-radius: var(--btn-border-radius);
        border-bottom-left-radius: 0;
      }
      
      &:last-child {
        border-top-right-radius: 0;
        border-bottom-right-radius: var(--btn-border-radius);
        border-bottom-left-radius: var(--btn-border-radius);
      }
      
      &:not(:first-child, :last-child) {
        border-top: 1px solid rgb(255 255 255 / 20%);
        border-left: none;
      }
    }
  }
}