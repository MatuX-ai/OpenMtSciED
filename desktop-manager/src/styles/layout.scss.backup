// Design Tokens - Layout System
//
// йҚҸг„Ҙзң¬з”ҜеҶЁзң¬зҖ№з‘°ж«’з»ҜиҚӨзІәй”ӣеұҫеҪҒжёҡж¶ҳжҗ·жҗҙж–ҝзҙЎз”ҜеҶЁзң¬з‘ҷпҪ…е–…йҸӮи§„о”Қ

// еҜје…Ҙ Design Tokens
@import 'design-tokens/index';

// =============================================================================
// йҚ©иҷ№о”…зҖ№з‘°ж«’з»«?
// =============================================================================

/// ж ҮеҮҶеӣәе®ҡе®ҪеәҰе®№еҷЁ
.container {
  @include container(false, $container-max-width);
  
  // зҖ№з‘°ж«’ж·ҮоҮҖгӮ°з»«?
  &--small {
    @include container(false, 800px);
  }
  
  &--large {
    @include container(false, 1400px);
  }
  
  &--fluid {
    @include container(true);
  }
  
  &--full {
    @include container(true);

    padding: 0;
  }
}

/// еЁҙдҪ·з¶ӢзҖ№з‘°ж«’й”ӣ?00%зҖ№и—үе®ій”ӣ?
.container-fluid {
  @include container(true);
}

// =============================================================================
// зјғжҲһзүёз»ҜиҚӨзІә
// =============================================================================

/// зјғжҲһзүёзҖ№з‘°ж«’
.grid {
  @include grid-container;
  
  // зјғжҲһзүёж·ҮоҮҖгӮ°з»«?
  &--gutter-sm {
    margin: 0 (-$spacing-sm / 2);
    
    > .grid-col {
      padding: 0 ($spacing-sm / 2);
    }
  }
  
  &--gutter-lg {
    margin: 0 (-$spacing-lg / 2);
    
    > .grid-col {
      padding: 0 ($spacing-lg / 2);
    }
  }
  
  &--align-start {
    align-items: flex-start;
  }
  
  &--align-center {
    align-items: center;
  }
  
  &--align-end {
    align-items: flex-end;
  }
  
  &--justify-start {
    justify-content: flex-start;
  }
  
  &--justify-center {
    justify-content: center;
  }
  
  &--justify-end {
    justify-content: flex-end;
  }
  
  &--justify-between {
    justify-content: space-between;
  }
  
  &--justify-around {
    justify-content: space-around;
  }
}

/// зјғжҲһзүёйҚ’?
.grid-col {
  @include grid-column(12); // жҰӣжЁҝо…»йҚ—зҠіеј§йҸҒзЈӢо”‘
  
  // йҚқе¶…з°ІеҜ®еҝ“еһӘзҖ№?
  &--1 { @include grid-column(1); }
  &--2 { @include grid-column(2); }
  &--3 { @include grid-column(3); }
  &--4 { @include grid-column(4); }
  &--5 { @include grid-column(5); }
  &--6 { @include grid-column(6); }
  &--7 { @include grid-column(7); }
  &--8 { @include grid-column(8); }
  &--9 { @include grid-column(9); }
  &--10 { @include grid-column(10); }
  &--11 { @include grid-column(11); }
  &--12 { @include grid-column(12); }
  
  // йҚӢеҝ•Р©й–Іеҝ•иў«
  &--offset-1 { margin-left: grid-width(1); }
  &--offset-2 { margin-left: grid-width(2); }
  &--offset-3 { margin-left: grid-width(3); }
  &--offset-4 { margin-left: grid-width(4); }
  &--offset-5 { margin-left: grid-width(5); }
  &--offset-6 { margin-left: grid-width(6); }
  &--offset-7 { margin-left: grid-width(7); }
  &--offset-8 { margin-left: grid-width(8); }
  &--offset-9 { margin-left: grid-width(9); }
  &--offset-10 { margin-left: grid-width(10); }
  &--offset-11 { margin-left: grid-width(11); }
}

// =============================================================================
// йҚқе¶…з°ІеҜ®еҝ“з«·зҒһвӮ¬з»«?
// =============================================================================

/// йҚқе¶…з°ІеҜ®еҝӣж®Јй’ҳ?йҸ„еү§гҒҡ
.hidden {
  &--mobile {
    @include hidden-at(mobile);
  }
  
  &--tablet {
    @include hidden-at(tablet);
  }
  
  &--desktop {
    @include hidden-at(desktop);
  }
}

.visible {
  &--mobile {
    @include visible-at(mobile);

    display: none;
  }
  
  &--tablet {
    @include visible-at(tablet);

    display: none;
  }
  
  &--desktop {
    @include visible-at(desktop);

    display: none;
  }
}

// =============================================================================
// Flexbox з”ҜеҶЁзң¬е®ёгғҘеҸҝз»«?
// =============================================================================

/// Flex зҖ№з‘°ж«’
.flex {
  display: flex;
  
  // йҸӮз‘°жӮң
  &--row { flex-direction: row; }
  &--row-reverse { flex-direction: row-reverse; }
  &--column { flex-direction: column; }
  &--column-reverse { flex-direction: column-reverse; }
  
  // йҺ№гҲЈо”‘
  &--wrap { flex-wrap: wrap; }
  &--nowrap { flex-wrap: nowrap; }
  &--wrap-reverse { flex-wrap: wrap-reverse; }
  
  // зҖөеҪ’з¶ҲйҸӮз‘°зҙЎ
  &--items-start { align-items: flex-start; }
  &--items-center { align-items: center; }
  &--items-end { align-items: flex-end; }
  &--items-baseline { align-items: baseline; }
  &--items-stretch { align-items: stretch; }
  
  &--justify-start { justify-content: flex-start; }
  &--justify-center { justify-content: center; }
  &--justify-end { justify-content: flex-end; }
  &--justify-between { justify-content: space-between; }
  &--justify-around { justify-content: space-around; }
  &--justify-evenly { justify-content: space-evenly; }
  
  // йҚҗе‘ӯоҶҗзҖөеҪ’з¶Ҳ
  &--content-start { align-content: flex-start; }
  &--content-center { align-content: center; }
  &--content-end { align-content: flex-end; }
  &--content-between { align-content: space-between; }
  &--content-around { align-content: space-around; }
  &--content-stretch { align-content: stretch; }
}

/// Flex жӨӨеңӯжҙ°
.flex-item {
  // йҸҖеүҒзјүйҚңеұҪо–ғй—Җ?
  &--grow { flex-grow: 1; }
  &--no-grow { flex-grow: 0; }
  &--shrink { flex-shrink: 1; }
  &--no-shrink { flex-shrink: 0; }
  
  // йҚ©иҷ№о”…жҫ¶Сғзҡ¬
  &--basis-auto { flex-basis: auto; }
  &--basis-0 { flex-basis: 0; }
  &--basis-full { flex-basis: 100%; }
  
  // зҖөеҪ’з¶Ҳ
  &--self-auto { align-self: auto; }
  &--self-start { align-self: flex-start; }
  &--self-center { align-self: center; }
  &--self-end { align-self: flex-end; }
  &--self-stretch { align-self: stretch; }
  &--self-baseline { align-self: baseline; }
}

// =============================================================================
// й—ӮзЈӢзӘӣе®ёгғҘеҸҝз»«?
// =============================================================================

/// йҚҗе‘°з«ҹз’әжҝҲиў«
.p {
  &--0 { padding: 0; }
  &--1 { padding: $spacing-xs; }    // 4px
  &--2 { padding: $spacing-sm; }    // 8px
  &--3 { padding: $spacing-md; }    // 12px
  &--4 { padding: $spacing-lg; }    // 16px
  &--5 { padding: $spacing-xl; }    // 24px
  &--6 { padding: $spacing-xxl; }   // 32px
  
  // йҸӮз‘°жӮңйҺ¬Сғе”ҙжқҲзЎ…зӘӣ
  &y--1 { padding-top: $spacing-xs; padding-bottom: $spacing-xs; }
  &y--2 { padding-top: $spacing-sm; padding-bottom: $spacing-sm; }
  &y--3 { padding-top: $spacing-md; padding-bottom: $spacing-md; }
  &y--4 { padding-top: $spacing-lg; padding-bottom: $spacing-lg; }
  &y--5 { padding-top: $spacing-xl; padding-bottom: $spacing-xl; }
  &y--6 { padding-top: $spacing-xxl; padding-bottom: $spacing-xxl; }
  
  &x--1 { padding-right: $spacing-xs; padding-left: $spacing-xs; }
  &x--2 { padding-right: $spacing-sm; padding-left: $spacing-sm; }
  &x--3 { padding-right: $spacing-md; padding-left: $spacing-md; }
  &x--4 { padding-right: $spacing-lg; padding-left: $spacing-lg; }
  &x--5 { padding-right: $spacing-xl; padding-left: $spacing-xl; }
  &x--6 { padding-right: $spacing-xxl; padding-left: $spacing-xxl; }
}

/// жҫ¶ж ¬з«ҹз’әжҝҲиў«
.m {
  &--0 { margin: 0; }
  &--1 { margin: $spacing-xs; }     // 4px
  &--2 { margin: $spacing-sm; }     // 8px
  &--3 { margin: $spacing-md; }     // 12px
  &--4 { margin: $spacing-lg; }     // 16px
  &--5 { margin: $spacing-xl; }     // 24px
  &--6 { margin: $spacing-xxl; }    // 32px
  &--auto { margin: auto; }
  
  // йҸӮз‘°жӮңйҺ¬Сғоҳ»жқҲзЎ…зӘӣ
  &y--1 { margin-top: $spacing-xs; margin-bottom: $spacing-xs; }
  &y--2 { margin-top: $spacing-sm; margin-bottom: $spacing-sm; }
  &y--3 { margin-top: $spacing-md; margin-bottom: $spacing-md; }
  &y--4 { margin-top: $spacing-lg; margin-bottom: $spacing-lg; }
  &y--5 { margin-top: $spacing-xl; margin-bottom: $spacing-xl; }
  &y--6 { margin-top: $spacing-xxl; margin-bottom: $spacing-xxl; }
  &y--auto { margin-top: auto; margin-bottom: auto; }
  
  &x--1 { margin-right: $spacing-xs; margin-left: $spacing-xs; }
  &x--2 { margin-right: $spacing-sm; margin-left: $spacing-sm; }
  &x--3 { margin-right: $spacing-md; margin-left: $spacing-md; }
  &x--4 { margin-right: $spacing-lg; margin-left: $spacing-lg; }
  &x--5 { margin-right: $spacing-xl; margin-left: $spacing-xl; }
  &x--6 { margin-right: $spacing-xxl; margin-left: $spacing-xxl; }
  &x--auto { margin-right: auto; margin-left: auto; }
}

// =============================================================================
// йҚқе¶…з°ІеҜ®еҝ“оҶҗйҚЈг„ҘеҪүжөЈ?
// =============================================================================

/// йҚқе¶…з°ІеҜ®еҝ“оҶҗйҚЈ?
@media (min-width: $breakpoint-tablet-min) {
  .container\@tablet {
    @include container(false, $container-max-width);
  }
  
  .container-fluid\@tablet {
    @include container(true);
  }
}

@media (min-width: $breakpoint-desktop-min) {
  .container\@desktop {
    @include container(false, $container-max-width);
  }
  
  .container-fluid\@desktop {
    @include container(true);
  }
}

// =============================================================================
// зҖ№зӮөж•Өз”ҜеҶЁзң¬з»«?
// =============================================================================

/// зҒһе‘¬и…‘зҖөеҪ’з¶Ҳ
.center {
  text-align: center;
  
  &--block {
    margin: 0 auto;
  }
  
  &--flex {
    display: flex;
    justify-content: center;
    align-items: center;
  }
}

/// еЁ“е‘ҙж«ҺеЁҙоҶје§©
.clearfix {
  &::after {
  display: table;
  clear: both;
  content: "";
}
}

/// йҸӮеӣЁж№°йҺҙоҒ…жҹҮ
.truncate {
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

/// жҫ¶ж°іо”‘йҸӮеӣЁж№°йҺҙоҒ…жҹҮ
.line-clamp {
  &--2 {
    displ{
  display: -webkit-box;
  overflow: hidden;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
} {
    display: -webkit-box{
  display: -webkit-box;
  overflow: hidden;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
}: -webkit-box;
    overflow{
  display: -webkit-box;
  overflow: hidden;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 4;
}
  -ms-overflow-style: none;
  scrollbar-width: none;
  
  &::-webkit-scrollbar {
    display: none;
  }
}