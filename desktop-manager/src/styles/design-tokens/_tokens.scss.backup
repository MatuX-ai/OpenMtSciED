// Design Tokens - 缁熶竴鍙橀噺绯荤粺
// 浠嶫SON tokens鑷姩鐢熸垚鐨凷CSS鍙橀噺锛屼緵Angular Material鍜屽叾浠栫粍浠朵娇鐢?

// 棰滆壊鍙橀噺 (鍩轰簬 colors.json)
$color-primary: #2196f3;
$color-primary-light: #64b5f6;
$color-primary-dark: #1976d2;
$color-secondary: #9c27b0;
$color-secondary-light: #ba68c8;
$color-secondary-dark: #7b1fa2;
$color-success: #4caf50;
$color-warning: #ff9800;
$color-error: #f44336;
$color-info: #2196f3;
$color-black: #000;
$color-white: #fff;
$color-gray-50: #fafafa;
$color-gray-100: #f5f5f5;
$color-gray-200: #eee;
$color-gray-300: #e0e0e0;
$color-gray-400: #bdbdbd;
$color-gray-500: #9e9e9e;
$color-gray-600: #757575;
$color-gray-700: #616161;
$color-gray-800: #424242;
$color-gray-900: #212121;
$color-text-primary: #212121;
$color-text-secondary: #757575;
$color-text-disabled: #9e9e9e;
$color-text-white: #fff;
$color-background: #fff;
$color-surface: #fff;
$color-divider: #e0e0e0;
$color-hover: #f5f5f5;
$color-selected: #e3f2fd;
$color-brand: #2196f3;
$color-link: #2196f3;
$color-link-hover: #1976d2;
$color-border: #e0e0e0;
$color-focus: #2196f3;
$color-placeholder: #9e9e9e;

// 瀛椾綋鍙橀噺 (鍩轰簬 fonts.json)
$font-family-sans: 'Helvetica Neue', helvetica, arial, sans-serif;
$font-family-serif: georgia, 'Times New Roman', times, serif;
$font-family-mono: 'Courier New', courier, monospace;
$font-family-system: -apple-system, blinkmacsystemfont, 'Segoe UI', roboto, oxygen, ubuntu, cantarell, sans-serif;
$font-size-h1: 2.5rem; // 40px
$font-size-h2: 2rem;   // 32px
$font-size-h3: 1.75rem; // 28px
$font-size-h4: 1.5rem;  // 24px
$font-size-h5: 1.25rem; // 20px
$font-size-h6: 1.125rem; // 18px
$font-size-body-large: 1rem;   // 16px
$font-size-body-medium: 0.875rem; // 14px
$font-size-body-small: 0.75rem;   // 12px
$font-size-caption: 0.625rem;    // 10px

$line-height-tight: 1.2;
$line-height-snug: 1.375;
$line-height-normal: 1.5;
$line-height-relaxed: 1.625;
$line-height-loose: 2;
$font-weight-thin: 100;
$font-weight-extra-light: 200;
$font-weight-light: 300;
$font-weight-regular: 400;
$font-weight-medium: 500;
$font-weight-semi-bold: 600;
$font-weight-bold: 700;
$font-weight-extra-bold: 800;
$font-weight-black: 900;

// 闂磋窛鍙橀噺 (鍩轰簬 spacing.json)
$spacing-xxs: 0.125rem; // 2px
$spacing-xs: 0.25rem;   // 4px
$spacing-sm: 0.5rem;    // 8px
$spacing-md: 0.75rem;   // 12px
$spacing-lg: 1rem;      // 16px
$spacing-xl: 1.5rem;    // 24px
$spacing-xxl: 2rem;     // 32px
$spacing-xxxl: 2.5rem;  // 40px
$spacing-xxxxl: 3rem;   // 48px
$spacing-xxxxxl: 3.5rem; // 56px
$spacing-xxxxxxl: 4rem;  // 64px
$spacing-huge: 5rem;    // 80px
$spacing-giant: 6rem;   // 96px
$spacing-massive: 8rem; // 128px

// 鍦嗚鍙橀噺 (鍩轰簬 border-radius.json)
$border-radius-none: 0;
$border-radius-xs: 0.125rem; // 2px
$border-radius-sm: 0.25rem;  // 4px
$border-radius-md: 0.5rem;   // 8px
$border-radius-lg: 0.75rem;  // 12px
$border-radius-xl: 1rem;     // 16px
$border-radius-full: 9999px;
$border-radius-button: 0.25rem;
$border-radius-input: 0.25rem;
$border-radius-card: 0.5rem;
$border-radius-modal: 0.75rem;
$border-radius-badge: 9999px;
$border-radius-avatar: 9999px;
$border-radius-dropdown: 0.5rem;
$border-radius-tooltip: 0.25rem;

// 闃村奖鍙橀噺 (鍩轰簬 shadows.json)
$shadow-none: none;
$shadow-xs: 0 1px 2px 0 rgb(0 0 0 / 5%);
$shadow-sm: 0 1px 3px 0 rgb(0 0 0 / 10%), 0 1px 2px 0 rgb(0 0 0 / 6%);
$shadow-md: 0 4px 6px -1px rgb(0 0 0 / 10%), 0 2px 4px -1px rgb(0 0 0 / 6%);
$shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 10%), 0 4px 6px -2px rgb(0 0 0 / 5%);
$shadow-xl: 0 20px 25px -5px rgb(0 0 0 / 10%), 0 10px 10px -5px rgb(0 0 0 / 4%);
$shadow-button: 0 1px 3px 0 rgb(0 0 0 / 10%), 0 1px 2px 0 rgb(0 0 0 / 6%);
$shadow-button-hover: 0 4px 6px -1px rgb(0 0 0 / 10%), 0 2px 4px -1px rgb(0 0 0 / 6%);
$shadow-card: 0 1px 3px 0 rgb(0 0 0 / 10%), 0 1px 2px 0 rgb(0 0 0 / 6%);
$shadow-card-hover: 0 4px 6px -1px rgb(0 0 0 / 10%), 0 2px 4px -1px rgb(0 0 0 / 6%);
$shadow-modal: 0 20px 25px -5px rgb(0 0 0 / 10%), 0 10px 10px -5px rgb(0 0 0 / 4%);
$shadow-dropdown: 0 10px 15px -3px rgb(0 0 0 / 10%), 0 4px 6px -2px rgb(0 0 0 / 5%);
$shadow-tooltip: 0 1px 3px 0 rgb(0 0 0 / 10%), 0 1px 2px 0 rgb(0 0 0 / 6%);
$shadow-navbar: 0 1px 3px 0 rgb(0 0 0 / 10%), 0 1px 2px 0 rgb(0 0 0 / 6%);
$shadow-focus: 0 0 0 3px rgb(33 150 243 / 30%);
$shadow-error: 0 0 0 3px rgb(244 67 54 / 30%);
$shadow-success: 0 0 0 3px rgb(76 175 80 / 30%);
$shadow-warning: 0 0 0 3px rgb(255 152 0 / 30%);

// 涓婚閰嶇疆鍙橀噺
$theme-primary: $color-primary;
$theme-secondary: $color-secondary;
$theme-success: $color-success;
$theme-warning: $color-warning;
$theme-error: $color-error;
$theme-info: $color-info;

// 鍝嶅簲寮忔柇鐐?
$breakpoint-mobile: 480px;
$breakpoint-tablet: 768px;
$breakpoint-desktop: 1024px;
$breakpoint-wide: 1200px;

// 鍔ㄧ敾鍜岃繃娓?
$transition-fast: 0.1s ease;
$transition-normal: 0.2s ease;
$transition-slow: 0.3s ease;

// Z-index 灞傜骇
$z-index-dropdown: 1000;
$z-index-sticky: 1020;
$z-index-fixed: 1030;
$z-index-modal-backdrop: 1040;
$z-index-modal: 1050;
$z-index-popover: 1060;
$z-index-tooltip: 1070;