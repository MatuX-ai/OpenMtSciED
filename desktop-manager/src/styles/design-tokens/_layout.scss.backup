// Design Tokens - Layout Variables
//
// 甯冨眬鐩稿叧鐨勮璁″彉閲忥紝鍖呮嫭鏂偣銆佸鍣ㄥ昂瀵搞€佺綉鏍肩郴缁熺瓑

// =============================================================================
// 鍝嶅簲寮忔柇鐐圭郴缁?
// =============================================================================

/// 绉诲姩绔渶澶у搴?
$breakpoint-mobile-max: 767px !default;

/// 骞虫澘绔渶灏忓搴?
$breakpoint-tablet-min: 768px !default;

/// 骞虫澘绔渶澶у搴?
$breakpoint-tablet-max: 1023px !default;

/// 妗岄潰绔渶灏忓搴?
$breakpoint-desktop-min: 1024px !default;

/// 澶ф闈㈢鏈€灏忓搴?
$breakpoint-desktop-large-min: 1200px !default;

// =============================================================================
// 瀹瑰櫒灏哄璁剧疆
// =============================================================================

/// 瀹瑰櫒鏈€澶у搴?
$container-max-width: 1200px !default;

/// 瀹瑰櫒鏈€灏忓搴?
$container-min-width: 320px !default;

// =============================================================================
// 瀹瑰櫒鍐呰竟璺濊缃?
// =============================================================================

/// 绉诲姩绔鍣ㄥ唴杈硅窛
$container-padding-mobile: $spacing-md !default; // 12px

/// 骞虫澘绔鍣ㄥ唴杈硅窛
$container-padding-tablet: $spacing-lg !default; // 16px

/// 妗岄潰绔鍣ㄥ唴杈硅窛
$container-padding-desktop: $spacing-xl !default; // 24px

/// 澶ф闈㈢瀹瑰櫒鍐呰竟璺?
$container-padding-desktop-large: $spacing-xxl !default; // 32px

// =============================================================================
// 缃戞牸绯荤粺
// =============================================================================

/// 缃戞牸鍒楁暟
$grid-columns: 12 !default;

/// 缃戞牸闂磋窛锛坓utter锛?
$grid-gutter: $spacing-md !default; // 12px

/// 缃戞牸闂磋窛 - 骞虫澘绔?
$grid-gutter-tablet: $spacing-lg !default; // 16px

/// 缃戞牸闂磋窛 - 妗岄潰绔?
$grid-gutter-desktop: $spacing-xl !default; // 24px

// =============================================================================
// 甯冨眬宸ュ叿 Mixins
// =============================================================================

/// 鍒涘缓鍝嶅簲寮忓鍣?
/// @param {Boolean} $fluid - 鏄惁涓烘祦浣撳鍣?
/// @param {String} $max-width - 鏈€澶у搴?
@mixin container($fluid: false, $max-width: $container-max-width) {
  width: 100%;
  
  @if not $fluid {
    max-width: $max-width;
    margin: 0 auto;
  }
  
  // 绉诲姩绔?
  padding: 0 $container-padding-mobile;
  
  // 骞虫澘绔?
  @media (min-width: $breakpoint-tablet-min) {
    padding: 0 $container-padding-tablet;
  }
  
  // 妗岄潰绔?
  @media (min-width: $breakpoint-desktop-min) {
    padding: 0 $container-padding-desktop;
  }
  
  // 澶ф闈㈢
  @media (min-width: $breakpoint-desktop-large-min) {
    padding: 0 $container-padding-desktop-large;
  }
}

/// 鍒涘缓缃戞牸瀹瑰櫒
@mixin grid-container {
  display: flex;
  flex-wrap: wrap;
  margin: 0 (-$grid-gutter / 2);
  
  // 骞虫澘绔?
  @media (min-width: $breakpoint-tablet-min) {
    margin: 0 (-$grid-gutter-tablet / 2);
  }
  
  // 妗岄潰绔?
  @media (min-width: $breakpoint-desktop-min) {
    margin: 0 (-$grid-gutter-desktop / 2);
  }
}

/// 鍒涘缓缃戞牸鍒?
/// @param {Number} $columns - 鍗犳嵁鐨勫垪鏁?
/// @param {Number} $total-columns - 鎬诲垪鏁?
@mixin grid-column($columns: 1, $total-columns: $grid-columns) {
  flex: 0 0 percentage($columns / $total-columns);
  max-width: percentage($columns / $total-columns);
  padding: 0 ($grid-gutter / 2);
  
  // 骞虫澘绔?
  @media (min-width: $breakpoint-tablet-min) {
    padding: 0 ($grid-gutter-tablet / 2);
  }
  
  // 妗岄潰绔?
  @media (min-width: $breakpoint-desktop-min) {
    padding: 0 ($grid-gutter-desktop / 2);
  }
}

/// 鍒涘缓鍝嶅簲寮忛殣钘忕被
/// @param {String} $breakpoint - 鏂偣 (mobile|tablet|desktop)
@mixin hidden-at($breakpoint) {
  @if $breakpoint == mobile {
    @media (max-width: $breakpoint-mobile-max) {
      display: none; /* 閫氳繃mixins璋冪敤鎻愰珮閫夋嫨鍣ㄧ壒寮傛€? */
    }
  } @else if $breakpoint == tablet {
    @media (min-width: $breakpoint-tablet-min) and (max-width: $breakpoint-tablet-max) {
      display: none; /* 閫氳繃mixins璋冪敤鎻愰珮閫夋嫨鍣ㄧ壒寮傛€? */
    }
  } @else if $breakpoint == desktop {
    @media (min-width: $breakpoint-desktop-min) {
      display: none; /* 閫氳繃mixins璋冪敤鎻愰珮閫夋嫨鍣ㄧ壒寮傛€? */
    }
  }
}

/// 鍒涘缓鍝嶅簲寮忔樉绀虹被
/// @param {String} $breakpoint - 鏂偣 (mobile|tablet|desktop)
@mixin visible-at($breakpoint) {
  @if $breakpoint == mobile {
    @media (max-width: $breakpoint-mobile-max) {
      display: block; /* 閫氳繃mixins璋冪敤鎻愰珮閫夋嫨鍣ㄧ壒寮傛€? */
    }
  } @else if $breakpoint == tablet {
    @media (min-width: $breakpoint-tablet-min) and (max-width: $breakpoint-tablet-max) {
      display: block; /* 閫氳繃mixins璋冪敤鎻愰珮閫夋嫨鍣ㄧ壒寮傛€? */
    }
  } @else if $breakpoint == desktop {
    @media (min-width: $breakpoint-desktop-min) {
      display: block; /* 閫氳繃mixins璋冪敤鎻愰珮閫夋嫨鍣ㄧ壒寮傛€? */
    }
  }
}

// =============================================================================
// 甯冨眬宸ュ叿鍑芥暟
// =============================================================================

/// 鑾峰彇鏂偣鍊?
/// @param {String} $breakpoint - 鏂偣鍚嶇О
/// @return {Number} 瀵瑰簲鐨勫儚绱犲€?
@function get-breakpoint($breakpoint) {
  @if $breakpoint == mobile {
    @return $breakpoint-mobile-max;
  } @else if $breakpoint == tablet {
    @return $breakpoint-tablet-min;
  } @else if $breakpoint == desktop {
    @return $breakpoint-desktop-min;
  } @else if $breakpoint == desktop-large {
    @return $breakpoint-desktop-large-min;
  } @else {
    @return $breakpoint-desktop-min;
  }
}

/// 璁＄畻缃戞牸瀹藉害
/// @param {Number} $columns - 鍒楁暟
/// @param {Number} $total-columns - 鎬诲垪鏁?
/// @return {Percentage} 璁＄畻鍚庣殑鐧惧垎姣斿搴?
@function grid-width($columns, $total-columns: $grid-columns) {
  @return percentage($columns / $total-columns);
}