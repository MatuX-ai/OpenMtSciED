// Design Tokens - Fonts
//
// 瀛椾綋璁捐鍙橀噺绯荤粺锛屽畾涔夐」鐩腑鐨勫瓧浣撴棌銆佸瓧鍙枫€佽楂樺拰瀛楅噸瑙勮寖

// 瀛椾綋鏃?
/// 榛樿鏃犺‖绾垮瓧浣?
$font-family-sans: 'Helvetica Neue', helvetica, arial, sans-serif !default;

/// 琛嚎瀛椾綋
$font-family-serif: georgia, 'Times New Roman', times, serif !default;

/// 绛夊瀛椾綋
$font-family-mono: 'Courier New', courier, monospace !default;

/// 绯荤粺瀛椾綋鍫嗘爤
$font-family-system: -apple-system, blinkmacsystemfont, 'Segoe UI', roboto, oxygen, ubuntu, cantarell, sans-serif !default;

// 瀛楀彿灞傜骇 - 鍩轰簬 16px 鏍瑰瓧浣撳ぇ灏?
/// 瓒呭ぇ鏍囬 (40px)
$font-size-h1: 2.5rem !default;

/// 澶ф爣棰?(32px)
$font-size-h2: 2rem !default;

/// 涓爣棰?(28px)
$font-size-h3: 1.75rem !default;

/// 灏忔爣棰?(24px)
$font-size-h4: 1.5rem !default;

/// 鍓爣棰?(20px)
$font-size-h5: 1.25rem !default;

/// 鏈€灏忔爣棰?(18px)
$font-size-h6: 1.125rem !default;

/// 澶ф鏂囧瓧浣?(16px)
$font-size-body-large: 1rem !default;

/// 涓瓑姝ｆ枃瀛椾綋 (14px)
$font-size-body-medium: 0.875rem !default;

/// 灏忔鏂囧瓧浣?(12px)
$font-size-body-small: 0.75rem !default;

/// 鏍囨敞瀛椾綋 (10px)
$font-size-caption: 0.625rem !default;

// 琛岄珮姣斾緥
/// 绱у噾琛岄珮
$line-height-tight: 1.2 !default;

/// 绋嶇揣琛岄珮
$line-height-snug: 1.375 !default;

/// 鏍囧噯琛岄珮
$line-height-normal: 1.5 !default;

/// 瀹芥澗琛岄珮
$line-height-relaxed: 1.625 !default;

/// 瓒呭鏉捐楂?
$line-height-loose: 2 !default;

// 瀛楅噸
/// 缁嗕綋
$font-weight-thin: 100 !default;

/// 瓒呯粏浣?
$font-weight-extra-light: 200 !default;

/// 缁嗕綋
$font-weight-light: 300 !default;

/// 甯歌
$font-weight-regular: 400 !default;

/// 涓瓑
$font-weight-medium: 500 !default;

/// 鍗婄矖浣?
$font-weight-semi-bold: 600 !default;

/// 绮椾綋
$font-weight-bold: 700 !default;

/// 瓒呯矖浣?
$font-weight-extra-bold: 800 !default;

/// 榛戜綋
$font-weight-black: 900 !default;

// 瀛椾綋缁勫悎鏍峰紡 Mixins
/// 椤甸潰鏍囬鏍峰紡
@mixin typography-page-title {
  font-family: $font-family-system;
  font-size: $font-size-h1;
  font-weight: $font-weight-bold;
  line-height: $line-height-tight;
}

/// 鍗＄墖鏍囬鏍峰紡
@mixin typography-card-title {
  font-family: $font-family-system;
  font-size: $font-size-h4;
  font-weight: $font-weight-semi-bold;
  line-height: $line-height-snug;
}

/// 姝ｆ枃澶у彿鏍峰紡
@mixin typography-body-large {
  font-family: $font-family-system;
  font-size: $font-size-body-large;
  font-weight: $font-weight-regular;
  line-height: $line-height-normal;
}

/// 姝ｆ枃涓彿鏍峰紡
@mixin typography-body-medium {
  font-family: $font-family-system;
  font-size: $font-size-body-medium;
  font-weight: $font-weight-regular;
  line-height: $line-height-normal;
}

/// 姝ｆ枃灏忓彿鏍峰紡
@mixin typography-body-small {
  font-family: $font-family-system;
  font-size: $font-size-body-small;
  font-weight: $font-weight-regular;
  line-height: $line-height-relaxed;
}

/// 鎸夐挳鏂囨湰鏍峰紡
@mixin typography-button {
  font-family: $font-family-system;
  font-size: $font-size-body-medium;
  font-weight: $font-weight-medium;
  line-height: $line-height-normal;
}

/// 杈撳叆妗嗗崰浣嶇鏍峰紡
@mixin typography-input-placeholder {
  font-family: $font-family-system;
  font-size: $font-size-body-medium;
  font-weight: $font-weight-regular;
  line-height: $line-height-normal;
}

// 瀛椾綋宸ュ叿鍑芥暟
/// 鑾峰彇瀛椾綋澶у皬
/// @param {String} $size - 瀛楀彿鏍囪瘑 (h1-h6, body-large, body-medium, body-small, caption)
/// @return {String} 瀵瑰簲鐨勫瓧浣撳ぇ灏忓€?
@function get-font-size($size) {
  @if $size == h1 {
    @return $font-size-h1;
  } @else if $size == h2 {
    @return $font-size-h2;
  } @else if $size == h3 {
    @return $font-size-h3;
  } @else if $size == h4 {
    @return $font-size-h4;
  } @else if $size == h5 {
    @return $font-size-h5;
  } @else if $size == h6 {
    @return $font-size-h6;
  } @else if $size == body-large {
    @return $font-size-body-large;
  } @else if $size == body-medium {
    @return $font-size-body-medium;
  } @else if $size == body-small {
    @return $font-size-body-small;
  } @else if $size == caption {
    @return $font-size-caption;
  } @else {
    @return $font-size-body-medium;
  }
}

/// 鑾峰彇琛岄珮鍊?
/// @param {String} $height - 琛岄珮鏍囪瘑 (tight, snug, normal, relaxed, loose)
/// @return {Number} 瀵瑰簲鐨勮楂樺€?
@function get-line-height($height) {
  @if $height == tight {
    @return $line-height-tight;
  } @else if $height == snug {
    @return $line-height-snug;
  } @else if $height == normal {
    @return $line-height-normal;
  } @else if $height == relaxed {
    @return $line-height-relaxed;
  } @else if $height == loose {
    @return $line-height-loose;
  } @else {
    @return $line-height-normal;
  }
}

/// 鑾峰彇瀛楅噸鍊?
/// @param {String} $weight - 瀛楅噸鏍囪瘑 (thin, light, regular, medium, bold, black)
/// @return {Number} 瀵瑰簲鐨勫瓧閲嶅€?
@function get-font-weight($weight) {
  @if $weight == thin {
    @return $font-weight-thin;
  } @else if $weight == extra-light {
    @return $font-weight-extra-light;
  } @else if $weight == light {
    @return $font-weight-light;
  } @else if $weight == regular {
    @return $font-weight-regular;
  } @else if $weight == medium {
    @return $font-weight-medium;
  } @else if $weight == semi-bold {
    @return $font-weight-semi-bold;
  } @else if $weight == bold {
    @return $font-weight-bold;
  } @else if $weight == extra-bold {
    @return $font-weight-extra-bold;
  } @else if $weight == black {
    @return $font-weight-black;
  } @else {
    @return $font-weight-regular;
  }
}