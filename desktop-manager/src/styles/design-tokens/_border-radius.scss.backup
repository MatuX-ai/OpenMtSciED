// Design Tokens - Border Radius
//
// 鍦嗚璁捐鍙橀噺绯荤粺锛屽畾涔夌粺涓€鐨勭粍浠跺渾瑙掕鑼?
// 纭繚鐣岄潰鍏冪礌鍏锋湁鍗忚皟涓€鑷寸殑鍦嗚鏁堟灉

// 鍦嗚灏哄瑙勮寖
/// 鏃犲渾瑙?
$border-radius-none: 0 !default;

/// 鏋佸皬鍦嗚 - 鐢ㄤ簬缁嗗井鐨勫渾瑙掓晥鏋?(2px)
$border-radius-xs: 0.125rem !default;

/// 灏忓渾瑙?- 鐢ㄤ簬鎸夐挳銆佽緭鍏ユ绛夊熀纭€缁勪欢 (4px)
$border-radius-sm: 0.25rem !default;

/// 涓瓑鍦嗚 - 鐢ㄤ簬鍗＄墖銆侀潰鏉跨瓑瀹瑰櫒缁勪欢 (8px)
$border-radius-md: 0.5rem !default;

/// 澶у渾瑙?- 鐢ㄤ簬鐗硅壊鍗＄墖銆佹ā鎬佹绛?(12px)
$border-radius-lg: 0.75rem !default;

/// 瓒呭ぇ鍦嗚 - 鐢ㄤ簬绐佸嚭鏄剧ず鐨勭粍浠?(16px)
$border-radius-xl: 1rem !default;

/// 瀹屽叏鍦嗗舰 - 鐢ㄤ簬澶村儚銆佸窘绔犵瓑鍦嗗舰鍏冪礌
$border-radius-full: 9999px !default;

// 缁勪欢鐗瑰畾鍦嗚
/// 鎸夐挳鍦嗚
$border-radius-button: $border-radius-sm !default;

/// 杈撳叆妗嗗渾瑙?
$border-radius-input: $border-radius-sm !default;

/// 鍗＄墖鍦嗚
$border-radius-card: $border-radius-md !default;

/// 妯℃€佹鍦嗚
$border-radius-modal: $border-radius-lg !default;

/// 寰界珷鍦嗚
$border-radius-badge: $border-radius-full !default;

/// 澶村儚鍦嗚
$border-radius-avatar: $border-radius-full !default;

/// 涓嬫媺鑿滃崟鍦嗚
$border-radius-dropdown: $border-radius-md !default;

/// 鎻愮ず妗嗗渾瑙?
$border-radius-tooltip: $border-radius-sm !default;

// 鏂瑰悜鎬у渾瑙?
/// 椤堕儴宸︿晶鍦嗚
$border-top-left-radius: $border-radius-md !default;

/// 椤堕儴鍙充晶鍦嗚
$border-top-right-radius: $border-radius-md !default;

/// 搴曢儴宸︿晶鍦嗚
$border-bottom-left-radius: $border-radius-md !default;

/// 搴曢儴鍙充晶鍦嗚
$border-bottom-right-radius: $border-radius-md !default;

// 鍝嶅簲寮忓渾瑙?
/// 绉诲姩绔寜閽渾瑙?
$border-radius-mobile-button: $border-radius-sm !default;

/// 绉诲姩绔崱鐗囧渾瑙?
$border-radius-mobile-card: $border-radius-md !default;

/// 绉诲姩绔ā鎬佹鍦嗚
$border-radius-mobile-modal: $border-radius-lg !default;

/// 妗岄潰绔寜閽渾瑙?
$border-radius-desktop-button: $border-radius-xs !default;

/// 妗岄潰绔崱鐗囧渾瑙?
$border-radius-desktop-card: $border-radius-sm !default;

/// 妗岄潰绔ā鎬佹鍦嗚
$border-radius-desktop-modal: $border-radius-md !default;

// 鍦嗚 Mixins
/// 搴旂敤鎸囧畾鍦嗚
/// @param {String} $radius - 鍦嗚澶у皬 (none|xs|sm|md|lg|xl|full)
@mixin border-radius($radius: md) {
  @if $radius == none {
    border-radius: $border-radius-none;
  } @else if $radius == xs {
    border-radius: $border-radius-xs;
  } @else if $radius == sm {
    border-radius: $border-radius-sm;
  } @else if $radius == md {
    border-radius: $border-radius-md;
  } @else if $radius == lg {
    border-radius: $border-radius-lg;
  } @else if $radius == xl {
    border-radius: $border-radius-xl;
  } @else if $radius == full {
    border-radius: $border-radius-full;
  } @else {
    border-radius: $border-radius-md;
  }
}

/// 搴旂敤缁勪欢鐗瑰畾鍦嗚
/// @param {String} $component - 缁勪欢绫诲瀷 (button|input|card|modal|badge|avatar|dropdown|tooltip)
@mixin component-border-radius($component: card) {
  @if $component == button {
    border-radius: $border-radius-button;
  } @else if $component == input {
    border-radius: $border-radius-input;
  } @else if $component == card {
    border-radius: $border-radius-card;
  } @else if $component == modal {
    border-radius: $border-radius-modal;
  } @else if $component == badge {
    border-radius: $border-radius-badge;
  } @else if $component == avatar {
    border-radius: $border-radius-avatar;
  } @else if $component == dropdown {
    border-radius: $border-radius-dropdown;
  } @else if $component == tooltip {
    border-radius: $border-radius-tooltip;
  } @else {
    border-radius: $border-radius-card;
  }
}

/// 搴旂敤鏂瑰悜鎬у渾瑙?
/// @param {String} $direction - 鏂瑰悜 (top-left|top-right|bottom-left|bottom-right)
/// @param {String} $radius - 鍦嗚澶у皬
@mixin directional-border-radius($direction, $radius: md) {
  $radius-value: get-border-radius($radius);
  
  @if $direction == top-left {
    border-top-left-radius: $radius-value;
  } @else if $direction == top-right {
    border-top-right-radius: $radius-value;
  } @else if $direction == bottom-left {
    border-bottom-left-radius: $radius-value;
  } @else if $direction == bottom-right {
    border-bottom-right-radius: $radius-value;
  }
}

/// 鍝嶅簲寮忓渾瑙?
/// @param {String} $breakpoint - 鏂偣 (mobile|desktop)
/// @param {String} $component - 缁勪欢绫诲瀷
@mixin responsive-border-radius($breakpoint: mobile, $component: card) {
  @if $breakpoint == mobile {
    @if $component == button {
      border-radius: $border-radius-mobile-button;
    } @else if $component == card {
      border-radius: $border-radius-mobile-card;
    } @else if $component == modal {
      border-radius: $border-radius-mobile-modal;
    }
  } @else if $breakpoint == desktop {
    @if $component == button {
      border-radius: $border-radius-desktop-button;
    } @else if $component == card {
      border-radius: $border-radius-desktop-card;
    } @else if $component == modal {
      border-radius: $border-radius-desktop-modal;
    }
  }
}

// 鍦嗚宸ュ叿鍑芥暟
/// 鑾峰彇鍦嗚鍊?
/// @param {String} $size - 鍦嗚鏍囪瘑 (none|xs|sm|md|lg|xl|full)
/// @return {String} 瀵瑰簲鐨勫渾瑙掑€?
@function get-border-radius($size) {
  @if $size == none {
    @return $border-radius-none;
  } @else if $size == xs {
    @return $border-radius-xs;
  } @else if $size == sm {
    @return $border-radius-sm;
  } @else if $size == md {
    @return $border-radius-md;
  } @else if $size == lg {
    @return $border-radius-lg;
  } @else if $size == xl {
    @return $border-radius-xl;
  } @else if $size == full {
    @return $border-radius-full;
  } @else {
    @return $border-radius-md;
  }
}

/// 鍒涘缓鍦嗚缁勫悎
/// @param {String} $top-left - 宸︿笂鍦嗚
/// @param {String} $top-right - 鍙充笂鍦嗚
/// @param {String} $bottom-right - 鍙充笅鍦嗚
/// @param {String} $bottom-left - 宸︿笅鍦嗚
/// @return {String} 鍥涗釜鍦嗚鍊肩殑缁勫悎
@function border-radius-combine($top-left: none, $top-right: none, $bottom-right: none, $bottom-left: none) {
  @return "#{get-border-radius($top-left)} #{get-border-radius($top-right)} #{get-border-radius($bottom-right)} #{get-border-radius($bottom-left)}";
}

/// 搴旂敤鍦嗚鍒伴€夋嫨鍣?
/// @param {String} $selector - CSS 閫夋嫨鍣?
/// @param {String} $radius - 鍦嗚澶у皬
/// @return {String} 鐢熸垚鐨?CSS 瑙勫垯
@function apply-border-radius($selector, $radius: md) {
  @return "#{$selector} { border-radius: #{get-border-radius($radius)}; }";
}