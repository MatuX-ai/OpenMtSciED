// Design Tokens SCSS Index
//
// Design Token SCSS 绯荤粺鍏ュ彛鏂囦欢
// 缁熶竴瀵煎叆鎵€鏈?SCSS 璁捐鍙橀噺

// 瀵煎叆鎵€鏈夎璁″彉閲?
@import 'colors';
@import 'fonts';
@import 'spacing';
@import 'border-radius';
@import 'shadows';
@import 'layout';

// 浣跨敤绀轰緥 Mixins
/// 搴旂敤鍩虹鍗＄墖鏍峰紡
/// @param {String} $padding-size - 鍐呰竟璺濆ぇ灏?
/// @param {String} $border-radius - 鍦嗚澶у皬
/// @param {String} $shadow - 闃村奖澶у皬
@mixin base-card($padding-size: md, $border-radius: md, $shadow: sm) {
  @include padding($padding-size);
  @include border-radius($border-radius);
  @include shadow($shadow);

  border: 1px solid $border-color;
  background-color: $surface-color;
}

/// 搴旂敤鍩虹鎸夐挳鏍峰紡
/// @param {String} $bg-color - 鑳屾櫙鑹?
/// @param {String} $text-color - 鏂囧瓧鑹?
/// @param {String} $hover-bg - 鎮仠鑳屾櫙鑹?
@mixin base-button($bg-color: $primary-color, $text-color: $text-white-color, $hover-bg: $primary-color-dark) {
  @include typography-button;
  @include border-radius(button);
  @include shadow(button);

  border: none;
  background-color: $bg-color;
  color: $text-color;
  cursor: pointer;
  transition: all 0.2s ease-in-out;
  
  &:hover {
    @include shadow(button-hover);

    background-color: $hover-bg;
  }
  
  &:focus {
    @include state-shadow(focus);

    outline: none;
  }
  
  &:disabled {
    @include shadow(none);

    background-color: $gray-300;
    color: $text-disabled-color;
    cursor: not-allowed;
  }
}

/// 搴旂敤鍩虹杈撳叆妗嗘牱寮?
@mixin base-input {
  @include typography-body-medium;
  @include border-radius(input);

  padding: $spacing-sm $spacing-md;
  border: 1px solid $border-color;
  background-color: $background-color;
  color: $text-primary-color;
  transition: border-color 0.2s ease-in-out;
  
  &:focus {
    @include state-shadow(focus);

    border-color: $focus-color;
    outline: none;
  }
  
  &::placeholder {
    color: $placeholder-color;
  }
  
  &:disabled {
    background-color: $gray-100;
    color: $text-disabled-color;
    cursor: not-allowed;
  }
}

/// 搴旂敤鍝嶅簲寮忓竷灞€瀹瑰櫒
/// @param {String} $breakpoint - 鏂偣
@mixin responsive-container($breakpoint: mobile) {
  width: 100%;
  margin: 0 auto;
  
  @if $breakpoint == mobile {
    max-width: 100%;

    @include responsive-padding(mobile, md);
  } @else if $breakpoint == tablet {
    max-width: 768px;

    @include responsive-padding(tablet, lg);
  } @else if $breakpoint == desktop {
    max-width: 1200px;

    @include responsive-padding(desktop, xl);
  }
}

// 涓婚鍙橀噺闆嗗悎
/// 榛樿涓婚鍙橀噺
$theme-default: (
  primary: $primary-color,
  secondary: $secondary-color,
  success: $success-color,
  warning: $warning-color,
  error: $error-color,
  background: $background-color,
  surface: $surface-color,
  text-primary: $text-primary-color,
  text-secondary: $text-secondary-color,
);

/// 鏆楄壊涓婚鍙橀噺
$theme-dark: (
  primary: $primary-color-light,
  secondary: $secondary-color-light,
  success: $success-color,
  warning: $warning-color,
  error: $error-color,
  background: $gray-900,
  surface: $gray-800,
  text-primary: $text-white-color,
  text-secondary: $gray-300,
);