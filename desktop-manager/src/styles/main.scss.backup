//       linear-gradient(rgba(0, 0, 255, 0.1) 1px, transparent 1px),
//       linear-gradient(90deg, rgba(0, 0, 255, 0.1) 1px, transparent 1px);
//     background-size: 20px 20px;
//   }
//   
//   // 甯冨眬杈圭晫璋冭瘯
//   .debug-boundary {
//     outline: 1px solid red;
//   }
// }

// =============================================================================
// 13. 绗笁鏂圭粍浠舵牱寮忚鐩栵紙濡傛湁闇€瑕侊級
// =============================================================================

// 鍙互鍦ㄨ繖閲岃鐩栫涓夋柟缁勪欢搴撶殑鏍峰紡
// 纭繚杩欎簺鏍峰紡鍏锋湁瓒冲鐨勭壒寮傛€?

// =============================================================================
// 14. Angular Material 闆嗘垚
// =============================================================================

// 搴旂敤浜壊涓婚
@include mat.core;
@include mat.all-component-themes($light-theme);

// 鏆楄壊涓婚 (閫氳繃灞炴€ч€夋嫨鍣ㄦ縺娲?
[data-theme="dark"] {
  @include mat.all-component-themes($dark-theme);
}

// Material 缁勪欢鏍峰紡澧炲己
.mat-mdc-button {
  border-radius: $border-radius-button;
  font-family: $font-family-system;
  font-weight: $font-weight-medium;
  transition: all $transition-normal;
}

.mat-mdc-card {
  border-radius: $border-radius-card;
  box-shadow: $shadow-card;
  transition: box-shadow $transition-normal;
  
  &:hover {
    box-shadow: $shadow-card-hover;
  }
}

.mat-mdc-form-field {
  font-family: $font-family-system;
  
  .mat-mdc-text-field-wrapper {
    border-radius: $border-radius-input;
  }
}



// 鍙闂€у寮?
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    transition-duration: 0.01ms;
    animation-duration: 0.01ms;
    animation-iteration-count: 1;
  }
}

