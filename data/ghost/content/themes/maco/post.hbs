{{!< default}}

<article class="post-article {{post_class}}">
  
  <!-- Post Header -->
  <header class="post-header">
    <div class="container container-narrow">
      {{#if primary_tag}}
        <span class="post-tag" style="color: var(--color-primary); font-weight: var(--font-medium); text-transform: uppercase; letter-spacing: 0.05em; font-size: var(--text-xs);">
          {{primary_tag.name}}
        </span>
      {{/if}}
      
      <h1 class="post-title">{{title}}</h1>
      
      {{#if custom_excerpt}}
        <p class="post-excerpt">{{custom_excerpt}}</p>
      {{/if}}
      
      <!-- Post Meta -->
      <div class="post-meta">
        <div class="post-author">
          {{#if primary_author}}
            {{#if primary_author.profile_image}}
              <img src="{{primary_author.profile_image}}" 
                   alt="{{primary_author.name}}" 
                   class="author-avatar"
                   width="40"
                   height="40"
                   loading="lazy">
            {{else}}
              <div class="author-avatar-placeholder">
                {{primary_author.name.[0]}}
              </div>
            {{/if}}
            
            <div class="author-info">
              <span class="author-name">
                <a href="{{primary_author.url}}">{{primary_author.name}}</a>
              </span>
              <time datetime="{{date format="YYYY-MM-DD"}}" 
                    class="post-date"
                    style="font-size: var(--text-xs); color: var(--text-tertiary);">
                {{date format="MMMM DD, YYYY"}}
                
                {{#if reading_time}}
                  · {{reading_time minute=(t "minute") minutes=(t "minutes")}} read
                {{/if}}
              </time>
            </div>
          {{/if}}
        </div>
      </div>
    </div>
  </header>
  
  <!-- Feature Image -->
  {{#if feature_image}}
    <figure class="post-feature-image">
      <img src="{{img_url feature_image size="xlarge"}}" 
           alt="{{title}}" 
           class="feature-image"
           loading="lazy">
      
      {{#if feature_image_caption}}
        <figcaption class="feature-caption">{{feature_image_caption}}</figcaption>
      {{/if}}
    </figure>
  {{/if}}
  
  <!-- Post Content -->
  <div class="container container-narrow">
    <div class="post-content">
      {{content}}
    </div>
    
    <!-- Post Tags -->
    {{#if tags}}
      <div class="post-tags">
        {{#foreach tags}}
          <a href="{{url}}" class="tag-link">
            <span class="tag">{{name}}</span>
          </a>
        {{/foreach}}
      </div>
    {{/if}}
    
    <!-- Post Navigation -->
    <nav class="post-navigation">
      {{#if prev_post}}
        <a href="{{prev_post.url}}" class="post-nav-link post-nav-prev">
          <span class="post-nav-label">Previous</span>
          <h4 class="post-nav-title">{{prev_post.title}}</h4>
        </a>
      {{/if}}
      
      {{#if next_post}}
        <a href="{{next_post.url}}" class="post-nav-link post-nav-next">
          <span class="post-nav-label">Next</span>
          <h4 class="post-nav-title">{{next_post.title}}</h4>
        </a>
      {{/if}}
    </nav>
    
    <!-- Comments Section (Optional) -->
    {{#if @comments.enabled}}
      <div class="post-comments">
        {{comments}}
      </div>
    {{/if}}
  </div>
  
</article>

<!-- Article Styles -->
<style>
  .post-article {
    padding-top: calc(52px + var(--spacing-3xl));
  }
  
  .post-header {
    padding: var(--spacing-3xl) 0;
    text-align: center;
  }
  
  .post-title {
    font-size: clamp(32px, 6vw, 48px);
    line-height: var(--leading-tight);
    margin-bottom: var(--spacing-md);
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }
  
  .post-excerpt {
    font-size: var(--text-xl);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    max-width: 600px;
    margin: 0 auto var(--spacing-xl);
  }
  
  .post-meta {
    display: flex;
    justify-content: center;
    margin-top: var(--spacing-xl);
  }
  
  .post-author {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
  }
  
  .author-avatar,
  .author-avatar-placeholder {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-full);
    object-fit: cover;
  }
  
  .author-avatar-placeholder {
    background: var(--color-primary);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: var(--font-semibold);
    font-size: var(--text-lg);
  }
  
  .author-info {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
  }
  
  .author-name a {
    font-weight: var(--font-medium);
    color: var(--text-primary);
  }
  
  .post-feature-image {
    margin: var(--spacing-3xl) 0;
    max-width: var(--container-max);
    margin-left: auto;
    margin-right: auto;
  }
  
  .feature-image {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
  }
  
  .feature-caption {
    text-align: center;
    font-size: var(--text-sm);
    color: var(--text-tertiary);
    margin-top: var(--spacing-sm);
    font-style: italic;
  }
  
  .post-content {
    padding: var(--spacing-2xl) 0;
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
  }
  
  /* Typography in content */
  .post-content h2 {
    margin-top: var(--spacing-3xl);
    margin-bottom: var(--spacing-lg);
  }
  
  .post-content h3 {
    margin-top: var(--spacing-2xl);
    margin-bottom: var(--spacing-md);
  }
  
  .post-content p {
    margin-bottom: var(--spacing-lg);
  }
  
  .post-content img {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-md);
    margin: var(--spacing-xl) 0;
  }
  
  .post-content blockquote {
    border-left: 4px solid var(--color-primary);
    padding-left: var(--spacing-lg);
    margin: var(--spacing-xl) 0;
    font-style: italic;
    color: var(--text-secondary);
  }
  
  .post-content pre {
    background: var(--bg-secondary);
    padding: var(--spacing-lg);
    border-radius: var(--radius-md);
    overflow-x: auto;
    margin: var(--spacing-xl) 0;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }
  
  .post-content code {
    background: var(--bg-secondary);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: 0.9em;
  }
  
  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    margin: var(--spacing-2xl) 0;
    padding-top: var(--spacing-xl);
    border-top: 1px solid var(--border-color-light);
  }
  
  .tag-link {
    text-decoration: none;
  }
  
  .tag {
    display: inline-block;
    padding: var(--spacing-xs) var(--spacing-md);
    background: var(--bg-secondary);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    transition: all var(--transition-fast);
  }
  
  .tag:hover {
    background: var(--color-primary);
    color: white;
    text-decoration: none;
  }
  
  .post-navigation {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--spacing-lg);
    margin: var(--spacing-3xl) 0;
    padding: var(--spacing-xl) 0;
    border-top: 1px solid var(--border-color-light);
  }
  
  .post-nav-link {
    display: block;
    padding: var(--spacing-lg);
    border-radius: var(--radius-lg);
    background: var(--bg-secondary);
    transition: all var(--transition-base);
    text-decoration: none;
  }
  
  .post-nav-link:hover {
    background: var(--bg-tertiary);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }
  
  .post-nav-label {
    display: block;
    font-size: var(--text-xs);
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--spacing-sm);
  }
  
  .post-nav-title {
    font-size: var(--text-lg);
    color: var(--text-primary);
    margin: 0;
  }
  
  @media (max-width: 768px) {
    .post-title {
      font-size: clamp(28px, 8vw, 36px);
    }
    
    .post-content {
      font-size: var(--text-base);
    }
  }
</style>
