{{!< default}}

<!-- Hero Section - Apple Style -->
{{#if @custom.show_hero}}
<section class="hero">
  <div class="container">
    <div class="hero-content">
      <h1 class="hero-title">
        {{#if @custom.hero_title}}
          {{@custom.hero_title}}
        {{else}}
          Welcome to {{@site.title}}
        {{/if}}
      </h1>
      
      <p class="hero-subtitle">
        {{#if @custom.hero_subtitle}}
          {{@custom.hero_subtitle}}
        {{else}}
          Discover stories, insights, and ideas that matter to you.
        {{/if}}
      </p>
      
      <div class="hero-actions">
        {{#if @custom.hero_cta_url}}
          <a href="{{@custom.hero_cta_url}}" class="btn btn-primary btn-large">
            {{#if @custom.hero_cta_text}}
              {{@custom.hero_cta_text}}
            {{else}}
              Get Started
            {{/if}}
          </a>
        {{/if}}
        
        {{#if @custom.hero_secondary_cta_url}}
          <a href="{{@custom.hero_secondary_cta_url}}" class="btn btn-secondary btn-large">
            {{#if @custom.hero_secondary_cta_text}}
              {{@custom.hero_secondary_cta_text}}
            {{else}}
              Learn More
            {{/if}}
          </a>
        {{/if}}
      </div>
    </div>
  </div>
</section>
{{/if}}

<!-- Featured Posts (Optional) -->
{{#if @custom.show_featured_posts}}
  {{#get "posts" filter="featured:true" limit="3" as |featured|}}
    {{#if featured}}
      <section class="section" style="background: var(--bg-secondary);">
        <div class="container">
          <h2 class="text-center mb-4">Featured Stories</h2>
          
          <div class="featured-grid">
            {{#foreach featured}}
              <article class="card featured-card">
                {{#if feature_image}}
                  <img src="{{img_url feature_image size="medium"}}" 
                       alt="{{title}}" 
                       class="card-image"
                       loading="lazy">
                {{/if}}
                
                <div class="card-content">
                  <h3 class="card-title">
                    <a href="{{url}}">{{title}}</a>
                  </h3>
                  
                  <p class="card-excerpt">
                    {{excerpt words="30"}}
                  </p>
                  
                  <div class="card-meta">
                    <time datetime="{{date format="YYYY-MM-DD"}}" 
                          style="font-size: var(--text-xs); color: var(--text-tertiary);">
                      {{date format="MMMM DD, YYYY"}}
                    </time>
                    
                    {{#if primary_tag}}
                      <span class="tag" style="color: var(--color-primary); font-weight: var(--font-medium);">
                        {{primary_tag.name}}
                      </span>
                    {{/if}}
                  </div>
                </div>
              </article>
            {{/foreach}}
          </div>
        </div>
      </section>
    {{/if}}
  {{/get}}
{{/if}}

<!-- Latest Posts Grid -->
<section class="section">
  <div class="container">
    <h2 class="text-center mb-4">Latest Stories</h2>
    
    <div class="posts-grid">
      {{#foreach posts}}
        <article class="card post-card">
          {{#if feature_image}}
            <img src="{{img_url feature_image size="medium"}}" 
                 alt="{{title}}" 
                 class="card-image"
                 loading="lazy">
          {{/if}}
          
          <div class="card-content">
            <h3 class="card-title">
              <a href="{{url}}">{{title}}</a>
            </h3>
            
            <p class="card-excerpt">
              {{excerpt words="30"}}
            </p>
            
            <div class="card-meta">
              <time datetime="{{date format="YYYY-MM-DD"}}" 
                    style="font-size: var(--text-xs); color: var(--text-tertiary);">
                {{date format="MMMM DD, YYYY"}}
              </time>
              
              {{#if primary_tag}}
                <span class="tag" style="color: var(--color-primary); font-weight: var(--font-medium);">
                  {{primary_tag.name}}
                </span>
              {{/if}}
            </div>
          </div>
        </article>
      {{/foreach}}
    </div>
    
    <!-- Pagination -->
    {{pagination}}
  </div>
</section>

<!-- Hero Styles -->
<style>
  .hero {
    padding: var(--spacing-4xl) 0;
    background: linear-gradient(135deg, rgba(0, 122, 255, 0.05) 0%, rgba(52, 199, 89, 0.05) 100%);
    min-height: 60vh;
    display: flex;
    align-items: center;
  }
  
  .hero-content {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }
  
  .hero-title {
    font-size: clamp(40px, 8vw, 64px);
    font-weight: var(--font-bold);
    line-height: var(--leading-tight);
    margin-bottom: var(--spacing-lg);
    background: linear-gradient(135deg, var(--color-black) 0%, var(--color-gray-600) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  
  .hero-subtitle {
    font-size: clamp(18px, 3vw, 24px);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--spacing-2xl);
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }
  
  .hero-actions {
    display: flex;
    gap: var(--spacing-md);
    justify-content: center;
    flex-wrap: wrap;
  }
  
  .featured-grid,
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--spacing-xl);
  }
  
  @media (max-width: 768px) {
    .featured-grid,
    .posts-grid {
      grid-template-columns: 1fr;
    }
    
    .hero {
      padding: var(--spacing-3xl) 0;
      min-height: auto;
    }
  }
</style>
