{{!
  Author template for Maco theme
  Displays posts by a specific author
}}

{{!< default}}

<div class="container">
  <header class="archive-header">
    {{#if authors}}
      {{#foreach authors limit="1"}}
        {{#if profile_image}}
          <img src="{{profile_image}}" alt="{{name}}" class="author-avatar-large">
        {{else}}
          <div class="author-avatar-placeholder-large">{{name.[0]}}</div>
        {{/if}}
        
        <h1 class="archive-title">{{name}}</h1>
        
        {{#if bio}}
          <p class="archive-description">{{bio}}</p>
        {{/if}}
        
        <div class="author-meta">
          {{#if website}}
            <a href="{{website}}" target="_blank" rel="noopener" class="author-website">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                <polyline points="15 3 21 3 21 9"></polyline>
                <line x1="10" y1="14" x2="21" y2="3"></line>
              </svg>
              {{website}}
            </a>
          {{/if}}
          
          {{#if twitter}}
            <a href="{{twitter_url}}" target="_blank" rel="noopener" class="author-social">
              Twitter
            </a>
          {{/if}}
          
          {{#if facebook}}
            <a href="{{facebook_url}}" target="_blank" rel="noopener" class="author-social">
              Facebook
            </a>
          {{/if}}
        </div>
      {{/foreach}}
    {{/if}}
    
    <p class="archive-count">
      {{plural ../pagination.total empty='No posts' singular='% post' plural='% posts'}} by {{authors.[0].name}}
    </p>
  </header>
  
  <div class="posts-grid">
    {{#foreach posts}}
      {{> "post-card"}}
    {{/foreach}}
  </div>
  
  {{pagination}}
</div>

<style>
  .archive-header {
    text-align: center;
    padding: var(--spacing-4xl) 0;
    border-bottom: 1px solid var(--border-color-light);
    margin-bottom: var(--spacing-3xl);
  }
  
  .author-avatar-large,
  .author-avatar-placeholder-large {
    width: 120px;
    height: 120px;
    border-radius: var(--radius-full);
    margin: 0 auto var(--spacing-lg);
    object-fit: cover;
  }
  
  .author-avatar-placeholder-large {
    background: linear-gradient(135deg, var(--color-primary), var(--color-success));
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-4xl);
    font-weight: var(--font-bold);
  }
  
  .archive-title {
    font-size: var(--text-4xl);
    margin-bottom: var(--spacing-md);
  }
  
  .archive-description {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto var(--spacing-md);
  }
  
  .author-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-md);
    flex-wrap: wrap;
  }
  
  .author-website,
  .author-social {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-xs);
    font-size: var(--text-sm);
    color: var(--color-primary);
  }
  
  .author-website svg {
    width: 16px;
    height: 16px;
  }
  
  .archive-count {
    font-size: var(--text-sm);
    color: var(--text-tertiary);
  }
</style>
