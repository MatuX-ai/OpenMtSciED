<!DOCTYPE html>
<html lang="{{@site.lang}}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  
  <!-- SEO Meta Tags -->
  <title>{{meta_title}}</title>
  <meta name="description" content="{{meta_description}}">
  <meta name="robots" content="index, follow">
  
  <!-- Open Graph / Facebook -->
  {{og_image}}
  {{og_title}}
  {{og_description}}
  
  <!-- Twitter Card -->
  {{twitter_image}}
  {{twitter_title}}
  {{twitter_description}}
  
  <!-- Canonical URL -->
  <link rel="canonical" href="{{canonical_url}}">
  
  <!-- Favicon -->
  <link rel="icon" type="image/png" href="{{@site.icon}}">
  <link rel="apple-touch-icon" sizes="180x180" href="{{@site.icon}}">
  
  <!-- RSS Feed -->
  <link rel="alternate" type="application/rss+xml" title="{{@site.title}}" href="{{@site.url}}/rss/">
  
  <!-- Styles -->
  <link rel="stylesheet" href="{{asset "css/global.css"}}">
  
  <!-- Ghost Head -->
  {{ghost_head}}
</head>

<body class="{{body_class}}">
  
  <!-- Navigation -->
  {{> "navbar"}}
  
  <!-- Main Content -->
  <main class="site-main">
    {{{body}}}
  </main>
  
  <!-- Footer -->
  {{> "footer"}}
  
  <!-- Scripts -->
  <script src="{{asset "js/main.js"}}"></script>
  
  <!-- Ghost Foot -->
  {{ghost_foot}}
  
</body>
</html>
