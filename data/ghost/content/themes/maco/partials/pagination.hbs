{{!
  Pagination Component - Maco Theme
  Clean, Apple-style pagination
}}

<nav class="pagination">
  {{#if prev}}
    <a href="{{page_url prev}}" class="pagination-prev btn btn-secondary">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="m15 18-6-6 6-6"></path>
      </svg>
      Previous
    </a>
  {{/if}}
  
  <span class="pagination-info">
    Page {{page}} of {{pages}}
  </span>
  
  {{#if next}}
    <a href="{{page_url next}}" class="pagination-next btn btn-primary">
      Next
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="m9 18 6-6-6-6"></path>
      </svg>
    </a>
  {{/if}}
</nav>

<style>
  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-md);
    margin-top: var(--spacing-3xl);
    padding-top: var(--spacing-xl);
    border-top: 1px solid var(--border-color-light);
  }
  
  .pagination-prev,
  .pagination-next {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-sm);
  }
  
  .pagination-info {
    font-size: var(--text-sm);
    color: var(--text-tertiary);
  }
  
  @media (max-width: 768px) {
    .pagination {
      flex-wrap: wrap;
      gap: var(--spacing-sm);
    }
  }
</style>
