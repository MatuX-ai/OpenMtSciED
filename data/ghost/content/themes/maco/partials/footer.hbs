<footer class="footer">
  <div class="container">
    <div class="footer-content">
      <!-- Brand Section -->
      <div class="footer-section">
        <h4>{{@site.title}}</h4>
        <p style="color: var(--text-secondary); font-size: var(--text-sm); line-height: var(--leading-relaxed);">
          {{#if @site.description}}
            {{@site.description}}
          {{else}}
            A Mac-inspired minimalist Ghost theme featuring clean design and Apple aesthetics.
          {{/if}}
        </p>
      </div>
      
      <!-- Navigation Links -->
      {{#if @site.navigation}}
        <div class="footer-section">
          <h4>Navigation</h4>
          <ul>
            {{#foreach @site.navigation limit="5"}}
              <li>
                <a href="{{url absolute="true"}}">{{label}}</a>
              </li>
            {{/foreach}}
          </ul>
        </div>
      {{/if}}
      
      <!-- Social Links -->
      {{#if @site.facebook}}{{#or @site.twitter}}
        <div class="footer-section">
          <h4>Follow Us</h4>
          <ul>
            {{#if @site.facebook}}
              <li>
                <a href="{{facebook_url}}" target="_blank" rel="noopener">
                  Facebook
                </a>
              </li>
            {{/if}}
            {{#if @site.twitter}}
              <li>
                <a href="{{twitter_url}}" target="_blank" rel="noopener">
                  Twitter
                </a>
              </li>
            {{/if}}
          </ul>
        </div>
      {{/or}}{{/if}}
      
      <!-- Legal Links -->
      <div class="footer-section">
        <h4>Legal</h4>
        <ul>
          <li>
            <a href="/privacy/">Privacy Policy</a>
          </li>
          <li>
            <a href="/terms/">Terms of Service</a>
          </li>
        </ul>
      </div>
    </div>
    
    <!-- Footer Bottom -->
    <div class="footer-bottom">
      <div class="copyright">
        &copy; {{date format="YYYY"}} {{@site.title}}. All rights reserved.
      </div>
      
      <div class="powered-by">
        Powered by <a href="https://ghost.org" target="_blank" rel="noopener">Ghost</a> & 
        <a href="https://www.imato.com" target="_blank" rel="noopener">Maco Theme</a>
      </div>
    </div>
  </div>
</footer>
