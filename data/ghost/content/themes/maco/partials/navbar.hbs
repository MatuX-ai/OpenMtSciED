<header class="navbar{{#if @custom.header_style}} navbar-{{@custom.header_style}}{{/if}}">
  <div class="navbar-container">
    <!-- Brand -->
    <a href="{{@site.url}}" class="navbar-brand">
      {{#if @site.logo}}
        <img src="{{@site.logo}}" alt="{{@site.title}}" height="32">
      {{else}}
        {{@site.title}}
      {{/if}}
    </a>
    
    <!-- Desktop Menu -->
    <nav>
      <ul class="navbar-menu" id="navbar-menu">
        {{#foreach navigation}}
          <li class="nav-item">
            <a href="{{url absolute="true"}}">{{label}}</a>
          </li>
        {{/foreach}}
        
        <!-- Search Button (Optional) -->
        {{#if @custom.enable_search}}
          <li class="nav-item">
            <button class="btn btn-secondary" id="search-toggle">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"></circle>
                <path d="m21 21-4.35-4.35"></path>
              </svg>
            </button>
          </li>
        {{/if}}
      </ul>
    </nav>
    
    <!-- Mobile Menu Toggle -->
    <button class="mobile-menu-toggle" id="mobile-menu-toggle" aria-label="Toggle menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M3 12h18M3 6h18M3 18h18"></path>
      </svg>
    </button>
  </div>
  
  <!-- Search Overlay (Optional) -->
  {{#if @custom.enable_search}}
    <div class="search-overlay" id="search-overlay" style="display: none;">
      <div class="search-container">
        <input type="text" placeholder="Search..." class="search-input" id="search-input">
        <button class="search-close" id="search-close">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 6 6 18M6 6l12 12"></path>
          </svg>
        </button>
      </div>
    </div>
  {{/if}}
</header>
