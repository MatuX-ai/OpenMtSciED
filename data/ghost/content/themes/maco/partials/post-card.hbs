{{!
  Post Card Component - Maco Theme
  Reusable card component for displaying posts
}}

<article class="card post-card {{post_class}}">
  {{#if feature_image}}
    <a href="{{url}}" class="card-image-link">
      <img src="{{img_url feature_image size="medium"}}" 
           alt="{{title}}" 
           class="card-image"
           loading="lazy">
    </a>
  {{/if}}
  
  <div class="card-content">
    <h3 class="card-title">
      <a href="{{url}}">{{title}}</a>
    </h3>
    
    <p class="card-excerpt">
      {{excerpt words="30"}}
    </p>
    
    <div class="card-meta">
      <time datetime="{{date format="YYYY-MM-DD"}}" 
            class="post-date"
            style="font-size: var(--text-xs); color: var(--text-tertiary);">
        {{date format="MMMM DD, YYYY"}}
      </time>
      
      {{#if primary_tag}}
        <span class="tag" style="color: var(--color-primary); font-weight: var(--font-medium);">
          {{primary_tag.name}}
        </span>
      {{/if}}
    </div>
    
    {{#if primary_author}}
      <div class="card-author">
        {{#if primary_author.profile_image}}
          <img src="{{primary_author.profile_image}}" 
               alt="{{primary_author.name}}" 
               class="author-avatar-small"
               width="24"
               height="24"
               loading="lazy">
        {{else}}
          <div class="author-avatar-tiny">{{primary_author.name.[0]}}</div>
        {{/if}}
        <span class="author-name">{{primary_author.name}}</span>
      </div>
    {{/if}}
  </div>
</article>

<style>
  .card-image-link {
    display: block;
    overflow: hidden;
  }
  
  .card-image {
    width: 100%;
    height: 240px;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }
  
  .card:hover .card-image {
    transform: scale(1.05);
  }
  
  .card-author {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    margin-top: var(--spacing-md);
    padding-top: var(--spacing-md);
    border-top: 1px solid var(--border-color-light);
  }
  
  .author-avatar-small,
  .author-avatar-tiny {
    width: 24px;
    height: 24px;
    border-radius: var(--radius-full);
    object-fit: cover;
  }
  
  .author-avatar-tiny {
    background: var(--color-primary);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
  }
  
  .author-name {
    font-size: var(--text-xs);
    color: var(--text-secondary);
    font-weight: var(--font-medium);
  }
</style>
