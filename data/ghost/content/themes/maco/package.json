{
  "name": "maco",
  "description": "Mac 风格简约 Ghost 主题 - 苹果设计美学",
  "demo": "https://www.imato.com",
  "version": "1.0.0",
  "engines": {
    "ghost": ">=5.0.0"
  },
  "license": "MIT",
  "screenshots": {
    "desktop": "assets/images/screenshot-desktop.png",
    "mobile": "assets/images/screenshot-mobile.png"
  },
  "author": {
    "name": "iMatu Development Team",
    "email": "dev@imato.com",
    "url": "https://www.imato.com"
  },
  "gpm": {
    "type": "theme",
    "categories": [
      "Minimal",
      "Modern",
      "Business",
      "Magazine"
    ]
  },
  "keywords": [
    "ghost",
    "ghost-theme",
    "mac",
    "apple",
    "minimal",
    "clean",
    "modern",
    "responsive",
    "mobile-friendly"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/imato/maco-theme.git"
  },
  "config": {
    "posts_per_page": 9,
    "image_sizes": {
      "icon": {
        "width": 64,
        "height": 64
      },
      "small": {
        "width": 160,
        "height": 160
      },
      "medium": {
        "width": 320,
        "height": 320
      },
      "large": {
        "width": 640,
        "height": 640
      }
    }
  },
  "custom": {
    "header_style": {
      "type": "select",
      "options": [
        "light",
        "dark",
        "transparent"
      ],
      "default": "light"
    },
    "show_featured_posts": {
      "type": "boolean",
      "default": true
    },
    "accent_color": {
      "type": "color",
      "default": "#007AFF"
    }
  }
}
