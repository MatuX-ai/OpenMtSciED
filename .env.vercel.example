# ============================================
# Vercel 部署环境变量配置
# ============================================
#
# 使用方法：
# 1. 在 Vercel Dashboard 中进入项目设置
# 2. 导航到 Settings > Environment Variables
# 3. 添加以下变量（Production, Preview, Development 环境都需要）
#
# 注意：不要将此文件提交到版本控制系统！
# ============================================

# Supabase 数据库配置（必需）
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-id.supabase.co:5432/postgres

# Supabase API 配置（可选，用于客户端直连）
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# 应用配置
APP_NAME=iMato AI Service
APP_VERSION=1.0.0
DEBUG=False
HOST=0.0.0.0
PORT=3000

# JWT配置（生产环境必须修改）
SECRET_KEY=CHANGE-THIS-TO-A-SECURE-RANDOM-STRING-IN-PRODUCTION
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS配置 - 添加你的实际域名
ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-custom-domain.com

# 日志配置
LOG_LEVEL=WARNING
LOG_FILE=

# Neo4j（Vercel上通常禁用）
NEO4J_ENABLED=False

# 功能模块开关
ENABLE_AR_VR_ROUTES=False
ENABLE_AR_VR_MOCK_ROUTES=False
ENABLE_DIGITAL_TWIN_ROUTES=False
ENABLE_FEDERATED_ROUTES=False
ENABLE_MODEL_UPDATE_ROUTES=False
ENABLE_XR_GESTURE_ROUTES=False
