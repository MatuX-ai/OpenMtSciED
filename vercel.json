{
  "version": 2,
  "builds": [
    {
      "src": "website/**",
      "use": "@vercel/static"
    },
    {
      "src": "admin-web/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/admin-web/browser"
      }
    },
    {
      "src": "backend-next/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend-next/app/api/$1"
    },
    {
      "src": "/admin/(.*\\.(js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot))",
      "dest": "admin-web/$1"
    },
    {
      "src": "/admin/(.*)",
      "dest": "admin-web/index.html"
    },
    {
      "src": "/login",
      "dest": "website/login.html"
    },
    {
      "src": "/dashboard",
      "dest": "website/dashboard.html"
    },
    {
      "src": "/profile",
      "dest": "website/profile.html"
    },
    {
      "src": "/(.*)",
      "dest": "website/$1"
    }
  ]
}
