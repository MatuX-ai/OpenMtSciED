# OpenMTSciEd 环境变量配置示例
# 复制此文件为 .env.local 并填写实际值
# ⚠️ 重要：永远不要将 .env.local 提交到版本控制系统

# ============================================
# JWT 认证配置
# ============================================
# 生成强密钥: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production

# JWT Token 过期时间（分钟），默认7天
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ============================================
# PostgreSQL 数据库配置 (Neon)
# ============================================
# 格式: postgresql+asyncpg://user:password@host/dbname
DATABASE_URL=postgresql+asyncpg://neondb_owner:YOUR_PASSWORD@ep-raspy-shape-ao7ool7u-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# ============================================
# Neo4j 图数据库配置 (Neo4j Aura)
# ============================================
NEO4J_URI=bolt+s://YOUR_INSTANCE_ID.databases.neo4j.io
NEO4J_USERNAME=YOUR_USERNAME
NEO4J_PASSWORD=YOUR_STRONG_PASSWORD_HERE

# Neo4j HTTP API URI (用于某些查询)
NEO4J_HTTP_URI=https://YOUR_INSTANCE_ID.databases.neo4j.io/db/YOUR_INSTANCE_ID/query/v2

# ============================================
# CORS 配置
# ============================================
# 允许的域名列表，用逗号分隔
CORS_ORIGINS=http://localhost:4200,http://localhost:3000,https://yourdomain.com

# ============================================
# AI 服务配置 (可选)
# ============================================
LLM_API_KEY=your-openai-or-other-llm-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4

# ============================================
# 应用配置
# ============================================
APP_ENV=development  # development | production
DEBUG=true           # true | false
LOG_LEVEL=INFO       # DEBUG | INFO | WARNING | ERROR | CRITICAL

# ============================================
# 其他配置
# ============================================
# 数据目录路径
DATA_DIR=./data

# 缓存 TTL (秒)
CACHE_TTL=300
