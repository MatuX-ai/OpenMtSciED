# SMTP 配置（邮件发送功能）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=MatuX <noreply@matux.ai>

# 数据库配置（可选，如使用数据库）
DATABASE_URL=postgresql://user:password@localhost:5432/matux

# CORS 配置
ALLOWED_ORIGINS=http://localhost:4200,https://matux.ai

# 安全配置
SECRET_KEY=your-secret-key-here
