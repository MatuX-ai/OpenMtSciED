# APM监控环境配置文件
# 复制此文件为 .env 并根据实际环境修改配置

# === 基础APM配置 ===
SERVICE_NAME=imato-backend
ENABLE_TRACING=true
ENABLE_METRICS=true
SAMPLING_RATE=1.0

# === SkyWalking配置 ===
SKYWALKING_COLLECTOR=localhost:11800
SKYWALKING_PROTOCOL=grpc
SKYWALKING_AUTHENTICATION=

# === OpenTelemetry配置 ===
OTEL_COLLECTOR=localhost:4317
OTEL_SERVICE_NAME=imato-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# === Prometheus配置 ===
PROMETHEUS_PORT=9090
PROMETHEUS_METRICS_PATH=/metrics
PROMETHEUS_SCRAPE_INTERVAL=15s

# === Jaeger配置（可选）===
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831
JAEGER_SAMPLER_TYPE=const
JAEGER_SAMPLER_PARAM=1

# === Zipkin配置（可选）===
ZIPKIN_ENDPOINT=http://localhost:9411/api/v2/spans

# === 监控告警配置 ===
ALERT_MANAGER_URL=http://localhost:9093
MONITORING_ALERT_THRESHOLD=0.05  # 5%错误率阈值
MONITORING_LATENCY_THRESHOLD=2.0  # 2秒延迟阈值

# === 日志级别配置 ===
APM_LOG_LEVEL=INFO
TRACE_LOG_LEVEL=WARNING
METRICS_LOG_LEVEL=INFO

# === 性能优化配置 ===
MAX_TRACE_BATCH_SIZE=100
TRACE_FLUSH_INTERVAL=5
METRICS_FLUSH_INTERVAL=10