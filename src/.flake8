[flake8]
max-line-length = 88
max-complexity = 10
select = E,W,F,I,C,B,Q,T20
extend-ignore = 
    E203,   # whitespace before ':'
    E501,   # line too long (handled by black)
    W503,   # line break before binary operator
    C901    # function is too complex (handled separately)
exclude = 
    .git,
    __pycache__,
    dist,
    build,
    .venv,
    venv,
    migrations,
    alembic
per-file-ignores = 
    __init__.py:F401
    tests/*:S101,T201
    */conftest.py:S101