# 应用配置
APP_NAME=iMato AI Service
APP_VERSION=1.0.0
DEBUG=False  # 生产环境请保持 False
HOST=0.0.0.0
PORT=8000

# 数据库配置
DATABASE_URL=postgresql://user:password@localhost:5432/imato_ai

# JWT配置
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# OpenAI配置
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4-turbo

# Lingma配置
LINGMA_API_KEY=your-lingma-api-key
LINGMA_MODEL=lingma-code-pro

# DeepSeek配置
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-coder

# 其他AI提供商配置
ANTHROPIC_API_KEY=your-anthropic-api-key
GOOGLE_API_KEY=your-google-api-key

# 动态课程生成配置
DYNAMIC_COURSE_MODEL=gpt-3.5-turbo
DYNAMIC_COURSE_TEMPERATURE=0.7
DYNAMIC_COURSE_MAX_TOKENS=1500
DYNAMIC_COURSE_CACHE_TTL=3600
DYNAMIC_COURSE_RATE_LIMIT=10

# CORS配置
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/ai_service.log

# 许可证管理系统配置
# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1
REDIS_PASSWORD=

# 许可证配置
LICENSE_ISSUER=iMatuProject
LICENSE_AUDIENCE=enterprise
LICENSE_ALGORITHM=HS256
LICENSE_EXPIRATION_HOURS=24
LICENSE_KEY_LENGTH=32
LICENSE_PREFIX=LICENSE

# 缓存配置
CACHE_TTL_SECONDS=3600
CACHE_CLEANUP_INTERVAL=300

# Celery配置
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000
CELERY_TASK_ACKS_LATE=True
CELERY_TASK_REJECT_ON_WORKER_LOST=True
CELERY_WORKER_SEND_TASK_EVENTS=True
CELERY_TASK_TRACK_STARTED=True
CELERY_RESULT_EXPIRES=86400

# Celery 任务熔断器配置
CELERY_TASK_CIRCUIT_BREAKER_ENABLED=True
CELERY_TASK_DEFAULT_TIMEOUT=30
CELERY_TASK_SOFT_TIMEOUT=25
CELERY_TASK_HARD_TIMEOUT=60
CELERY_TASK_FAILURE_THRESHOLD=3
CELERY_TASK_CIRCUIT_TIMEOUT=30
CELERY_TASK_HALF_OPEN_ATTEMPTS=2
CELERY_ENABLE_TIMEOUT_PROTECTION=True
CELERY_ENABLE_FAILURE_PROTECTION=True

# Neo4j 图数据库配置
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=iMato-DB
NEO4J_ENABLED=True

# 可选路由配置 (控制功能模块的启用/禁用)
# 设置为 True 启用相应功能模块，False 禁用
ENABLE_AR_VR_ROUTES=False
ENABLE_AR_VR_MOCK_ROUTES=False
ENABLE_DIGITAL_TWIN_ROUTES=False
ENABLE_FEDERATED_ROUTES=False
ENABLE_MODEL_UPDATE_ROUTES=False
ENABLE_XR_GESTURE_ROUTES=False