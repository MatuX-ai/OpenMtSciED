{
  "version": 2,
  "functions": {
    "backend/openmtscied/main.py": {
      "runtime": "@vercel/python",
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/openmtscied/main.py"
    },
    {
      "src": "/health",
      "dest": "backend/openmtscied/main.py"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
